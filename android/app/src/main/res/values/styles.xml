<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema yang tampil selagi Flutter engine masih memuat, sebelum
         first frame digambar. Merujuk ke launch_background.xml agar
         tidak ada layar putih/hitam kosong sesaat sebelum app siap. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Tema normal dipakai Flutter setelah first frame digambar,
         menggantikan LaunchTheme. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
